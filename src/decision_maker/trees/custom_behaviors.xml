<root BTCPP_format="4">
    <TreeNodesModel>
        <Action ID="BlackboardManager">
            <output_port name="auto_aim_tracking" type="bool"/>
            <output_port name="projectile_allowance" type="long"/>
            <output_port name="center_area_state" type="unsigned char"/>
            <output_port name="rfid_state" type="unsigned char"/>
            <output_port name="state_remain_time" type="unsigned short"/>
            <output_port name="game_state" type="unsigned char"/>
            <output_port name="current_hp" type="unsigned short"/>
        </Action>
        <Action ID="NavToPose">
            <input_port name="goal" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;">goal send to navigator.</input_port>
        </Action>
        <Action ID="Test">
            <input_port name="val" type="unsigned short">dbg val</input_port>
            <input_port name="msg" type="std::string">dbg msg</input_port>
        </Action>
    </TreeNodesModel>
</root>
