<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="Untitled">
    <ReactiveSequence>
      <BlackboardManager auto_aim_tracking="{auto_aim_tracking}"
                         projectile_allowance="{projectile_allowance}"
                         target_position="{target_position}"
                         center_area_state="{center_area_state}"
                         rfid_state="{rfid_state}"
                         state_remain_time="{state_remain_time}"
                         game_state="{game_state}"
                         current_hp="{current_hp}"/>
      <Sequence>
        <FindEnemy nav_goal="{enemy_goal}"
                   target_position="{target_position}"/>
        <NavToPose goal="{enemy_goal}"/>
      </Sequence>
    </ReactiveSequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="BlackboardManager">
      <output_port name="auto_aim_tracking"
                   type="bool"/>
      <output_port name="projectile_allowance"
                   type="long"/>
      <output_port name="target_position"
                   type="std::string"/>
      <output_port name="center_area_state"
                   type="unsigned char"/>
      <output_port name="rfid_state"
                   type="unsigned char"/>
      <output_port name="state_remain_time"
                   type="unsigned short"/>
      <output_port name="game_state"
                   type="unsigned char"/>
      <output_port name="current_hp"
                   type="unsigned short"/>
    </Action>
    <Action ID="FindEnemy">
      <output_port name="nav_goal"
                   type="std::string">xyzabcw goal in odom frame</output_port>
      <input_port name="target_position"
                  type="std::string">xy target posi in base frame</input_port>
    </Action>
    <Action ID="NavToPose">
      <input_port name="goal"
                  type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;">goal send to navigator.</input_port>
    </Action>
  </TreeNodesModel>

</root>
