<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="Untitled">
    <Sequence>
      <BlackboardManager auto_aim_tracking="{auto_aim_tracking}"
                         projectile_allowance="{projectile_allowance}"
                         center_area_state="{center_area_state}"
                         rfid_state="{rfid_state}"
                         state_remain_time="{state_remain_time}"
                         game_state="{game_state}"
                         current_hp="{current_hp}"/>
      <Repeat num_cycles="3">
        <Test val="{current_hp}"
              msg=""/>
      </Repeat>
      <AlwaysSuccess/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="BlackboardManager">
      <output_port name="auto_aim_tracking"
                   type="bool"/>
      <output_port name="projectile_allowance"
                   type="long"/>
      <output_port name="center_area_state"
                   type="unsigned char"/>
      <output_port name="rfid_state"
                   type="unsigned char"/>
      <output_port name="state_remain_time"
                   type="unsigned short"/>
      <output_port name="game_state"
                   type="unsigned char"/>
      <output_port name="current_hp"
                   type="unsigned short"/>
    </Action>
    <Action ID="Test">
      <input_port name="val"
                  type="unsigned short">dbg val</input_port>
      <input_port name="msg"
                  type="std::string">dbg msg</input_port>
    </Action>
  </TreeNodesModel>

</root>
